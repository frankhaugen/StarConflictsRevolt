<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["StarConflictsRevolt.Clients.Blazor.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <HeadOutlet />
    
    <!-- Add debugging scripts -->
    <script>
        console.log('Star Conflicts Revolt - App starting...');
        
        // Global error handler
        window.addEventListener('error', function(e) {
            console.error('Global JavaScript Error:', e.error);
            console.error('Stack:', e.error?.stack);
        });
        
        // Blazor error handler
        window.addEventListener('unhandledrejection', function(e) {
            console.error('Unhandled Promise Rejection:', e.reason);
        });
        
        // Debug function for button clicks (call from Blazor if needed)
        window.debugButtonClick = function(buttonName) {
            console.log('Button clicked:', buttonName, new Date().toISOString());
        };

        // Register Blazor callback so button clicks are sent to the backend
        window._buttonActionDotNetRef = null;
        window.registerButtonActionReporter = function(dotNetRef) {
            window._buttonActionDotNetRef = dotNetRef;
        };

        // Global button-click: log and send to backend in *bubble* phase so Blazor's @@onclick runs first
        document.addEventListener('click', function(e) {
            var el = e.target;
            while (el && el !== document.body) {
                if (el.tagName === 'BUTTON' || (el.getAttribute && el.getAttribute('role') === 'button')) {
                    var label = (el.textContent || '').trim().slice(0, 80) || el.getAttribute('data-testid') || el.className || 'button';
                    var buttonId = (el.getAttribute && el.getAttribute('data-testid')) || null;
                    console.log('Button clicked:', label, new Date().toISOString());
                    if (window._buttonActionDotNetRef) {
                        window._buttonActionDotNetRef.invokeMethodAsync('ReportButtonAction', label, buttonId || '').catch(function() {});
                    }
                    break;
                }
                el = el.parentElement;
            }
        }, false);
        
        // Persistent player id for session resume (player tracking)
        window.getPlayerId = function() {
            var key = 'StarConflictsRevolt.PlayerId';
            try {
                var id = localStorage.getItem(key);
                if (!id) {
                    id = (typeof crypto !== 'undefined' && crypto.randomUUID) ? crypto.randomUUID() : 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) { var r = Math.random() * 16 | 0; var v = c === 'x' ? r : (r & 0x3 | 0x8); return v.toString(16); });
                    localStorage.setItem(key, id);
                }
                return id;
            } catch (e) {
                return 'anonymous-' + Math.random().toString(36).slice(2);
            }
        };

        // Debug function for navigation
        window.debugNavigation = function(url) {
            console.log('Navigating to:', url, new Date().toISOString());
        };
        
        // Debug function for service calls
        window.debugServiceCall = function(service, method, data) {
            console.log('Service call:', service, method, data);
        };
        
        // Ensure functions are available immediately
        console.log('Debug functions initialized:', {
            debugButtonClick: typeof window.debugButtonClick,
            debugNavigation: typeof window.debugNavigation,
            debugServiceCall: typeof window.debugServiceCall
        });
    </script>
</head>

<body>
    <Routes />
    <script src="_framework/blazor.web.js"></script>
    
    <!-- Additional debugging script -->
    <script>
        // Monitor DOM changes for debugging
        const observer = new MutationObserver(function(mutations) {
            mutations.forEach(function(mutation) {
                if (mutation.type === 'childList') {
                    console.log('DOM changed:', mutation.addedNodes.length, 'nodes added');
                }
            });
        });
        
        observer.observe(document.body, {
            childList: true,
            subtree: true
        });

        // Do not call Blazor.start() - blazor.web.js auto-starts Blazor. Calling it again causes "Blazor has already started".
        console.log('Star Conflicts Revolt - App initialized');
    </script>
</body>

</html>
