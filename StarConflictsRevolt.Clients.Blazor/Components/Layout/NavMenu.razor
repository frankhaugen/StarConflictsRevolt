@inject StarConflictsRevolt.Clients.Blazor.Services.IGameStateService GameState

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Star Conflicts Revolt</a>
    </div>
</div>

@if (GameState.CurrentSession != null)
{
    <div class="scr-session-strip" title="Game session you joined; receiving ticks and updates from this session">
        <span class="small text-muted">Joined / receiving from:</span>
        <div class="small fw-semibold text-truncate">@GameState.CurrentSession.SessionName</div>
    </div>
}
else
{
    <div class="scr-session-strip scr-session-strip-none">
        <span class="small text-muted">No game session selected</span>
    </div>
}

<input type="checkbox" title="Navigation menu" class="navbar-toggler" aria-label="Toggle navigation menu" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column" role="navigation" aria-label="Main">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">Home</NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="sessions">Sessions</NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="galaxy">Galaxy</NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="options">Options</NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="diagnostics">Diagnostics</NavLink>
        </div>
    </nav>
</div>

@code {
    protected override void OnInitialized()
    {
        GameState.StateChanged += OnGameStateChanged;
    }

    private void OnGameStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }
}

