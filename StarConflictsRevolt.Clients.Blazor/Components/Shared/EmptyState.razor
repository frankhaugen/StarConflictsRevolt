@* Reusable empty state: icon, title, optional description, and CTA slot. *@
<div class="scr-empty-state text-center @(Compact ? "py-2 px-2" : "py-5 px-3")">
    @if (!string.IsNullOrEmpty(IconClass))
    {
        <div class="scr-empty-state-icon @(Compact ? "mb-1" : "mb-3")">
            <i class="@IconClass @(Compact ? "fa-2x" : "fa-3x")" aria-hidden="true"></i>
        </div>
    }
    <h3 class="@(Compact ? "h6" : "h5") text-muted mb-1">@Title</h3>
    @if (!string.IsNullOrEmpty(Description) && !Compact)
    {
        <p class="text-muted small mb-3 mx-auto" style="max-width: 28rem;">@Description</p>
    }
    @if (Compact && !string.IsNullOrEmpty(Description))
    {
        <p class="text-muted small mb-0">@Description</p>
    }
    @if (ChildContent != null)
    {
        <div class="@(Compact ? "mt-2" : "mt-3")">@ChildContent</div>
    }
</div>

@code {
    [Parameter] public string Title { get; set; } = "Nothing here yet";
    [Parameter] public string? Description { get; set; }
    [Parameter] public string? IconClass { get; set; } = "fas fa-inbox";
    [Parameter] public bool Compact { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
