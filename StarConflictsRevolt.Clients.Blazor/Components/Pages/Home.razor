@page "/"
@rendermode InteractiveServer
@using StarConflictsRevolt.Clients.Blazor.Services
@using StarConflictsRevolt.Clients.Shared.Communication
@inject IGameStateService GameState
@inject ISignalRService SignalR
@inject NavigationManager Navigation

<PageTitle>Star Conflicts Revolt</PageTitle>

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6 text-center">
            <h1 data-testid="home-title" class="scr-title mb-4">STAR CONFLICTS REVOLT</h1>

            @if (!SignalR.IsConnected)
            {
                <p class="text-muted mb-3"><i class="fas fa-spinner fa-spin me-2"></i>Connecting to server…</p>
                <p class="small text-muted">Sessions and Galaxy are available from the menu once connected.</p>
            }
            else if (GameState.CurrentSession != null)
            {
                <p class="scr-text-bright mb-2">Game session active</p>
                <p class="text-muted small mb-3">@GameState.CurrentSession.SessionName</p>
                <a href="/galaxy" class="btn scr-hud-btn primary btn-lg" data-testid="continue-btn">
                    <i class="fas fa-play me-2"></i>Continue
                </a>
            }
            else
            {
                <p class="scr-text-bright mb-3">Select a game session</p>
                <a href="/sessions" class="btn scr-hud-btn primary btn-lg" data-testid="sessions-btn">
                    <i class="fas fa-list me-2"></i>Sessions
                </a>
            }
        </div>
    </div>
</div>

@code {
}
