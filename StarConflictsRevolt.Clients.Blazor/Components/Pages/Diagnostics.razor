@page "/diagnostics"
@rendermode InteractiveServer
@using StarConflictsRevolt.Clients.Blazor.Services
@using StarConflictsRevolt.Clients.Models
@using StarConflictsRevolt.Clients.Blazor.Models
@using StarConflictsRevolt.Clients.Shared.Authentication
@using StarConflictsRevolt.Clients.Shared.Http
@inject IGameStateService GameState
@inject BlazorSignalRService SignalRService
@inject TelemetryService TelemetryService
@inject NavigationManager Navigation
@inject ILogger<Diagnostics> Logger
@inject ITokenProvider TokenProvider
@inject IJSRuntime JSRuntime
@inject IJavaScriptInteropService JsInterop
@inject IHttpApiClient HttpApiClient

<PageTitle>System Diagnostics</PageTitle>

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 data-testid="diagnostics-title"><i class="fas fa-heartbeat text-danger"></i> System Diagnostics</h1>
                <button data-testid="refresh-btn" class="btn btn-outline-primary" @onclick="RefreshData" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                    }
                    else
                    {
                        <i class="fas fa-sync-alt"></i>
                    }
                    Refresh
                </button>
            </div>
        </div>
    </div>

    <!-- API Health Checks -->
    <div class="row">
        <div class="col-12 mb-4">
            <div class="card scr-panel">
                <div class="card-header">
                    <h5 data-testid="health-checks-header"><i class="fas fa-stethoscope"></i> API Health Checks</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-3">Ping API endpoints (raw GET, no pre-check). Results show status code, duration, and response body.</p>
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <button type="button" class="btn scr-hud-btn primary" data-testid="health-check-root" @onclick='() => RunHealthCheck("/")' disabled="@healthCheckRunning">
                            Check GET /
                        </button>
                        <button type="button" class="btn scr-hud-btn primary" data-testid="health-check-health" @onclick='() => RunHealthCheck("/health")' disabled="@healthCheckRunning">
                            Check GET /health
                        </button>
                        <button type="button" class="btn scr-hud-btn primary" data-testid="health-check-game" @onclick='() => RunHealthCheck("/health/game")' disabled="@healthCheckRunning">
                            Check GET /health/game
                        </button>
                        <button type="button" class="btn scr-hud-btn" data-testid="health-check-all" @onclick="RunAllHealthChecks" disabled="@healthCheckRunning">
                            Check all
                        </button>
                    </div>
                    @if (healthCheckResult != null)
                    {
                        <div class="health-result border rounded p-3 mb-2" data-testid="health-check-result">
                            <div class="d-flex justify-content-between align-items-start">
                                <span><strong>@healthCheckResult.Path</strong></span>
                                <span class="badge @(healthCheckResult.StatusCode >= 200 && healthCheckResult.StatusCode < 300 ? "bg-success" : "bg-danger")">@healthCheckResult.StatusCode</span>
                            </div>
                            <div class="small text-muted mt-1">@healthCheckResult.DurationMs ms</div>
                            @if (!string.IsNullOrEmpty(healthCheckResult.Error))
                            {
                                <pre class="small text-danger mt-2 mb-0">@healthCheckResult.Error</pre>
                            }
                            else if (!string.IsNullOrEmpty(healthCheckResult.Body))
                            {
                                <pre class="small mt-2 mb-0 text-break">@healthCheckResult.Body</pre>
                            }
                        </div>
                    }
                    @if (healthCheckResults?.Count > 0)
                    {
                        @foreach (var r in healthCheckResults)
                        {
                            <div class="health-result border rounded p-3 mb-2">
                                <div class="d-flex justify-content-between align-items-start">
                                    <span><strong>@r.Path</strong></span>
                                    <span class="badge @(r.StatusCode >= 200 && r.StatusCode < 300 ? "bg-success" : "bg-danger")">@r.StatusCode</span>
                                </div>
                                <div class="small text-muted mt-1">@r.DurationMs ms</div>
                                @if (!string.IsNullOrEmpty(r.Error))
                                {
                                    <pre class="small text-danger mt-2 mb-0">@r.Error</pre>
                                }
                                else if (!string.IsNullOrEmpty(r.Body))
                                {
                                    <pre class="small mt-2 mb-0 text-break">@r.Body</pre>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Authentication Status -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 data-testid="auth-status-header"><i class="fas fa-shield-alt"></i> Authentication Status</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-6">
                            <div class="d-flex align-items-center mb-2">
                                <div data-testid="auth-status" class="status-indicator @(isAuthenticated ? "connected" : "disconnected")"></div>
                                <span class="ms-2">Authentication</span>
                            </div>
                            <div class="d-flex align-items-center mb-2">
                                <div data-testid="token-status" class="status-indicator @(hasValidToken ? "connected" : "disconnected")"></div>
                                <span class="ms-2">JWT Token</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <small class="text-muted">
                                Token Expires: @tokenExpiry.ToString("HH:mm:ss")
                            </small>
                        </div>
                    </div>
                    @if (hasValidToken)
                    {
                        <div class="mt-2">
                            <small class="text-success">
                                <i class="fas fa-check-circle"></i> Token valid for @tokenTimeRemaining
                            </small>
                        </div>
                        <div class="mt-2">
                            <small class="text-info">
                                <i class="fas fa-key"></i> Token: @(currentToken != null ? $"{currentToken[..Math.Min(20, currentToken.Length)]}..." : "None")
                            </small>
                        </div>
                    }
                    else
                    {
                        <div class="mt-2">
                            <small class="text-warning">
                                <i class="fas fa-exclamation-triangle"></i> No valid token available
                            </small>
                        </div>
                        <div class="mt-2">
                            <button class="btn btn-sm btn-outline-primary" @onclick="RequestNewToken">
                                <i class="fas fa-refresh"></i> Request New Token
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Connection Status -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 data-testid="connection-status-header"><i class="fas fa-wifi"></i> Connection Status</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-6">
                            <div class="d-flex align-items-center mb-2">
                                <div data-testid="game-server-status" class="status-indicator @(GameState.IsConnected ? "connected" : "disconnected")"></div>
                                <span class="ms-2">Game Server</span>
                            </div>
                            <div class="d-flex align-items-center mb-2">
                                <div data-testid="signalr-status" class="status-indicator @(signalRConnected ? "connected" : "disconnected")"></div>
                                <span class="ms-2">SignalR</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <small class="text-muted">
                                Last Update: @lastUpdate.ToString("HH:mm:ss")
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Session Information -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 data-testid="session-info-header"><i class="fas fa-gamepad"></i> Session Information</h5>
                </div>
                <div class="card-body">
                    @if (GameState.CurrentSession != null)
                    {
                        <div class="mb-2">
                            <strong>Session:</strong> @GameState.CurrentSession.SessionName
                        </div>
                        <div class="mb-2">
                            <strong>Type:</strong> @GameState.CurrentSession.SessionType
                        </div>
                        <div class="mb-2">
                            <strong>Status:</strong> 
                            <span class="badge @(GameState.CurrentSession.IsActive ? "bg-success" : "bg-warning")">
                                @(GameState.CurrentSession.IsActive ? "Active" : "Waiting")
                            </span>
                        </div>
                        <div class="mb-2">
                            <strong>Created:</strong> @GameState.CurrentSession.Created.ToString("yyyy-MM-dd HH:mm:ss")
                        </div>
                    }
                    else
                    {
                        <div class="text-muted">No active session</div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- SignalR Statistics -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 data-testid="signalr-stats-header"><i class="fas fa-broadcast-tower"></i> SignalR Statistics</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-6">
                            <div class="metric-item">
                                <div class="metric-value">@signalRMessageCount</div>
                                <div class="metric-label">Messages Received</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="metric-item">
                                <div class="metric-value">@signalRReconnectCount</div>
                                <div class="metric-label">Reconnections</div>
                            </div>
                        </div>
                    </div>
                    <div class="row mt-3">
                        <div class="col-6">
                            <div class="metric-item">
                                <div class="metric-value">@lastSignalRMessage.ToString("HH:mm:ss")</div>
                                <div class="metric-label">Last Message</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="metric-item">
                                <div class="metric-value">@(lastTickNumber >= 0 ? lastTickNumber.ToString() : "—")</div>
                                <div class="metric-label">Last Tick</div>
                            </div>
                        </div>
                    </div>
                    <div class="row mt-1">
                        <div class="col-12">
                            <div class="metric-item">
                                <div class="metric-value small">@totalTicksReceived tick(s) received</div>
                                <div class="metric-label">@(GameState.CurrentSession != null && !signalRConnected
                                    ? "You have a session but real-time connection is not active. Re-join the session or refresh to receive ticks."
                                    : GameState.CurrentSession != null && signalRConnected
                                        ? "Tick log (connected)"
                                        : "Tick log (join a session to receive ticks)")</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- HTTP Statistics -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 data-testid="http-stats-header"><i class="fas fa-globe"></i> HTTP Statistics</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-6">
                            <div class="metric-item">
                                <div class="metric-value">@httpRequestCount</div>
                                <div class="metric-label">Requests Sent</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="metric-item">
                                <div class="metric-value">@httpErrorCount</div>
                                <div class="metric-label">Errors</div>
                            </div>
                        </div>
                    </div>
                    <div class="row mt-3">
                        <div class="col-12">
                            <div class="metric-item">
                                <div class="metric-value">@averageResponseTime ms</div>
                                <div class="metric-label">Avg Response Time</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Real-time Activity Log -->
        <div class="col-12 mb-4">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 data-testid="activity-log-header"><i class="fas fa-list"></i> Activity Log</h5>
                    <button data-testid="clear-log-btn" class="btn btn-sm btn-outline-secondary" @onclick="ClearLog">
                        <i class="fas fa-trash"></i> Clear
                    </button>
                </div>
                <div class="card-body">
                    <div data-testid="activity-log" class="activity-log" style="height: 360px; overflow-y: auto;">
                        @foreach (var logEntry in activityLog.Take(150))
                        {
                            <div class="log-entry @logEntry.Type.ToLower()">
                                <span class="log-time">[@logEntry.Timestamp.ToString("HH:mm:ss")]</span>
                                <span class="log-message">@logEntry.Message</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- See server events (tick / ReceiveUpdates batches) -->
        <div class="col-12 mb-4">
            <div class="card scr-panel">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 data-testid="server-events-header"><i class="fas fa-broadcast-tower"></i> See server events</h5>
                    <button data-testid="clear-server-events-btn" class="btn btn-sm btn-outline-secondary" @onclick="ClearServerEvents">
                        <i class="fas fa-trash"></i> Clear
                    </button>
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-3">All simulation ticks and ReceiveUpdates batches from the server. Join a session to see every tick and world update.</p>
                    @if (serverEventBatches.Count > 0)
                    {
                        <div class="small mb-2">Showing last @Math.Min(MaxServerEventsDisplay, serverEventBatches.Count) of @serverEventBatches.Count event batch(es)</div>
                    }
                    <div data-testid="server-events-log" class="server-events-log" style="height: 400px; overflow-y: auto; font-family: var(--bs-font-monospace); font-size: 0.8rem;">
                        @foreach (var batch in serverEventBatches.AsEnumerable().Reverse().Take(MaxServerEventsDisplay))
                        {
                            <div class="server-event-batch border-bottom mb-2 pb-2">
                                <div class="d-flex justify-content-between align-items-center text-nowrap flex-wrap gap-1">
                                    <span class="text-info">[@batch.Timestamp.ToString("HH:mm:ss.fff")]</span>
                                    @if (batch.TickNumber.HasValue)
                                    {
                                        <span class="badge bg-primary">Tick @batch.TickNumber.Value</span>
                                    }
                                    @if (batch.Updates.Count > 0)
                                    {
                                        <span class="badge bg-secondary">@batch.Updates.Count update@(batch.Updates.Count == 1 ? "" : "s")</span>
                                    }
                                </div>
                                @if (batch.Updates.Count > 0)
                                {
                                    <ul class="list-unstyled mb-0 mt-1 small">
                                        @foreach (var u in batch.Updates.Take(20))
                                        {
                                            <li class="text-break">
                                                <span class="text-warning">@u.Type</span> <span class="text-muted">@u.Id.ToString("N")[..8]…</span>
                                                @if (u.Data != null)
                                                {
                                                    var raw = u.Data.Value.GetRawText();
                                                    var preview = raw.Length > 120 ? raw.Substring(0, 120) + "…" : raw;
                                                    <span class="d-block text-muted ms-2">@preview</span>
                                                }
                                            </li>
                                        }
                                    </ul>
                                    @if (batch.Updates.Count > 20)
                                    {
                                        <div class="small text-muted mt-1">+ @(batch.Updates.Count - 20) more</div>
                                    }
                                }
                            </div>
                        }
                        @if (!serverEventBatches.Any())
                        {
                            <div class="text-muted small">No server events yet. Join a session to see simulation ticks and ReceiveUpdates batches.</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Performance Metrics -->
        <div class="col-12 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 data-testid="performance-metrics-header"><i class="fas fa-chart-line"></i> Performance Metrics</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <div class="metric-item">
                                <div class="metric-value">@memoryUsage MB</div>
                                <div class="metric-label">Memory Usage</div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="metric-item">
                                <div class="metric-value">@cpuUsage %</div>
                                <div class="metric-label">CPU Usage</div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="metric-item">
                                <div class="metric-value">@uptime</div>
                                <div class="metric-label">Uptime</div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="metric-item">
                                <div class="metric-value">@activeConnections</div>
                                <div class="metric-label">Active Connections</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Raw State Block -->
        <div class="col-12 mb-4">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 data-testid="raw-state-header"><i class="fas fa-code"></i> Raw State Block</h5>
                    <button data-testid="copy-state-btn" class="btn btn-sm btn-outline-primary" @onclick="CopyStateToClipboard">
                        <i class="fas fa-copy"></i> Copy
                    </button>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <small class="text-muted">This block contains the raw application state for debugging purposes.</small>
                    </div>
                    <div data-testid="raw-state-content" class="raw-state-block" style="background-color: #f8f9fa; border: 1px solid #dee2e6; border-radius: 0.375rem; padding: 1rem; font-family: 'Courier New', monospace; font-size: 0.875rem; white-space: pre-wrap; max-height: 400px; overflow-y: auto;">
@rawStateJson
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private bool isLoading = false;
    private bool healthCheckRunning = false;
    private HealthCheckResult? healthCheckResult = null;
    private List<HealthCheckResult>? healthCheckResults = null;
    private bool signalRConnected = false;
    private int signalRMessageCount = 0;
    private int signalRReconnectCount = 0;
    private DateTime lastSignalRMessage = DateTime.MinValue;
    private int httpRequestCount = 0;
    private int httpErrorCount = 0;
    private int averageResponseTime = 0;
    private long memoryUsage = 0;
    private int cpuUsage = 0;
    private string uptime = "00:00:00";
    private int activeConnections = 0;
    private DateTime lastUpdate = DateTime.Now;
    private List<LogEntry> activityLog = new();
    private Timer? refreshTimer;
    
    // Authentication status variables
    private bool isAuthenticated = false;
    private bool hasValidToken = false;
    private DateTime tokenExpiry = DateTime.MinValue;
    private string tokenTimeRemaining = "Unknown";
    private string? currentToken = null;
    
    // Raw state variables
    private string rawStateJson = "Loading...";

    // Server events: simulation ticks (ReceiveTick) and update batches (ReceiveUpdates)
    private readonly List<ServerEventBatch> serverEventBatches = new();
    private const int MaxServerEventBatches = 500;
    private const int MaxServerEventsDisplay = 200;
    private long lastTickNumber = -1;
    private long totalTicksReceived = 0;
    private bool? lastAuthLoggedState = null; // only add auth log when this changes

    private bool isFirstRender = true;

    protected override async Task OnInitializedAsync()
    {
        // Subscribe to all SignalR and app events so diagnostics shows everything
        SignalRService.FullWorldReceived += OnFullWorldReceived;
        SignalRService.TickReceived += OnTickReceived;
        SignalRService.UpdatesReceived += OnSignalRMessage;
        SignalRService.ConnectionClosed += OnSignalRConnectionClosed;
        SignalRService.Reconnecting += OnSignalRReconnecting;
        SignalRService.Reconnected += OnSignalRReconnected;
        
        GameState.StateChanged += OnGameStateChanged;
        
        // Start refresh timer
        refreshTimer = new Timer(RefreshDataCallback, null, TimeSpan.Zero, TimeSpan.FromSeconds(5));
        
        // Initial data load
        await RefreshDataAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            isFirstRender = false;
            await JsInterop.LogInfoAsync("Diagnostics component initializing");
            await JsInterop.LogInfoAsync("Diagnostics component initialized successfully");
        }
    }

    private async Task RefreshData()
    {
        isLoading = true;
        await RefreshDataAsync();
        AddLogEntry("info", "Diagnostics data refreshed");
        isLoading = false;
    }

    private async Task RefreshDataAsync()
    {
        try
        {
            // Update performance metrics
            await UpdatePerformanceMetrics();
            
            // Update connection status: Game Server = have session; SignalR = actual hub connection state
            signalRConnected = SignalRService.IsConnected;
            
            // Update authentication status
            await UpdateAuthenticationStatus();
            
            // Update raw state
            await UpdateRawState();
            
            lastUpdate = DateTime.Now;
            // Only add refresh log on manual refresh to reduce noise (timer still updates metrics)
        }
        catch (Exception ex)
        {
            AddLogEntry("error", $"Error refreshing data: {ex.Message}");
        }
    }

    private async Task UpdateAuthenticationStatus()
    {
        try
        {
            if (!isFirstRender)
            {
                await JsInterop.LogDebugAsync("Updating authentication status");
            }
            
            // Check if we have a valid token
            if (TokenProvider != null)
            {
                try
                {
                    currentToken = await TokenProvider.GetTokenAsync();
                    hasValidToken = !string.IsNullOrEmpty(currentToken);
                    
                    if (hasValidToken)
                    {
                        var timeRemaining = TimeSpan.FromHours(1); // Default assumption
                        tokenExpiry = DateTime.UtcNow.Add(timeRemaining);
                        tokenTimeRemaining = timeRemaining.ToString(@"hh\:mm\:ss");
                        isAuthenticated = true;
                    }
                    else
                    {
                        isAuthenticated = false;
                    }
                    // Only add activity log when auth status changes to avoid spam every 5s
                    if (lastAuthLoggedState != hasValidToken)
                    {
                        lastAuthLoggedState = hasValidToken;
                        if (hasValidToken)
                            AddLogEntry("success", "Authentication successful - valid token available");
                        else
                            AddLogEntry("warning", "No valid token available");
                    }
                }
                catch (Exception ex)
                {
                    isAuthenticated = false;
                    hasValidToken = false;
                    if (lastAuthLoggedState != false)
                    {
                        lastAuthLoggedState = false;
                        AddLogEntry("error", $"Authentication failed: {ex.Message}");
                    }
                    if (!isFirstRender)
                    {
                        await JsInterop.LogErrorAsync($"Authentication failed: {ex.Message}");
                        await JsInterop.LogExceptionAsync(ex);
                    }
                }
            }
            else
            {
                isAuthenticated = false;
                hasValidToken = false;
                if (lastAuthLoggedState != null)
                {
                    lastAuthLoggedState = null;
                    AddLogEntry("warning", "Token provider not available");
                }
            }
        }
        catch (Exception ex)
        {
            AddLogEntry("error", $"Error checking authentication status: {ex.Message}");
            if (!isFirstRender)
            {
                await JsInterop.LogErrorAsync($"Error checking authentication status: {ex.Message}");
                await JsInterop.LogExceptionAsync(ex);
            }
        }
    }

    private void RefreshDataCallback(object? state)
    {
        _ = Task.Run(RefreshDataAsync);
    }

    private async Task UpdatePerformanceMetrics()
    {
        try
        {
            // Get memory usage
            var process = System.Diagnostics.Process.GetCurrentProcess();
            memoryUsage = process.WorkingSet64 / 1024 / 1024; // Convert to MB
            
            // Update telemetry service with memory usage
            TelemetryService.UpdateMemoryUsage(process.WorkingSet64);
            
            // Calculate uptime
            var startTime = process.StartTime;
            var elapsed = DateTime.Now - startTime;
            uptime = elapsed.ToString(@"hh\:mm\:ss");
            
            // Simulate CPU usage (in a real implementation, you'd use proper CPU monitoring)
            cpuUsage = new Random().Next(10, 50);
            
            // Update active connections (simulated)
            activeConnections = signalRConnected ? 1 : 0;
            TelemetryService.UpdateActiveConnections(activeConnections);
            
            // Trigger UI update
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            AddLogEntry("error", $"Error updating performance metrics: {ex.Message}");
        }
    }

    private void OnFullWorldReceived(WorldDto world)
    {
        var idStr = world?.Id.ToString("N") ?? "";
        var idPreview = idStr.Length > 8 ? idStr[..8] + "…" : idStr;
        AddLogEntry("info", $"FullWorld received (WorldId: {idPreview}, Systems: {world?.Galaxy?.StarSystems?.Count() ?? 0})");
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnTickReceived(long tickNumber)
    {
        lastTickNumber = tickNumber;
        totalTicksReceived++;
        serverEventBatches.Add(new ServerEventBatch(DateTime.Now, tickNumber, new List<GameObjectUpdate>()));
        while (serverEventBatches.Count > MaxServerEventBatches)
            serverEventBatches.RemoveAt(0);
        AddLogEntry("info", $"Tick {tickNumber} received");
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnSignalRMessage(List<GameObjectUpdate> updates)
    {
        signalRMessageCount += updates.Count;
        lastSignalRMessage = DateTime.Now;
        AddLogEntry("info", $"Received {updates.Count} SignalR updates");
        // Append to server events view (each batch = one tick’s worth of updates)
        serverEventBatches.Add(new ServerEventBatch(DateTime.Now, null, new List<GameObjectUpdate>(updates)));
        while (serverEventBatches.Count > MaxServerEventBatches)
            serverEventBatches.RemoveAt(0);
        _ = InvokeAsync(StateHasChanged);
    }

    private void ClearServerEvents()
    {
        serverEventBatches.Clear();
        StateHasChanged();
    }

    private void OnSignalRConnectionClosed(Exception? exception)
    {
        signalRConnected = false;
        AddLogEntry("warning", $"SignalR connection closed: {exception?.Message ?? "Unknown reason"}");
    }

    private void OnSignalRReconnecting(Exception? exception)
    {
        AddLogEntry("info", "SignalR reconnecting...");
    }

    private void OnSignalRReconnected(string connectionId)
    {
        signalRConnected = true;
        signalRReconnectCount++;
        AddLogEntry("success", $"SignalR reconnected: {connectionId}");
    }

    private void OnGameStateChanged()
    {
        AddLogEntry("info", "Game state changed");
        _ = InvokeAsync(StateHasChanged);
    }

    private async void AddLogEntry(string type, string message)
    {
        var logEntry = new LogEntry
        {
            Timestamp = DateTime.Now,
            Type = type,
            Message = message
        };
        
        activityLog.Insert(0, logEntry);
        
        // Keep only last 300 entries so all events are visible without unbounded growth
        if (activityLog.Count > 300)
        {
            activityLog = activityLog.Take(300).ToList();
        }
        
        // Also log to JavaScript console (only if component is rendered)
        if (!isFirstRender)
        {
            try
            {
                var jsMessage = $"[{type.ToUpper()}] {message}";
                switch (type.ToLower())
                {
                    case "error":
                        await JsInterop.LogErrorAsync(jsMessage);
                        break;
                    case "warning":
                        await JsInterop.LogWarningAsync(jsMessage);
                        break;
                    case "success":
                        await JsInterop.LogInfoAsync(jsMessage);
                        break;
                    default:
                        await JsInterop.LogDebugAsync(jsMessage);
                        break;
                }
            }
            catch (Exception ex)
            {
                // Don't let JS logging errors break the main functionality
                Logger.LogWarning(ex, "Failed to log to JavaScript console");
            }
        }
        
        _ = InvokeAsync(StateHasChanged);
    }

    private void ClearLog()
    {
        activityLog.Clear();
    }

    private async Task UpdateRawState()
    {
        try
        {
            var state = new
            {
                Timestamp = DateTime.UtcNow,
                Application = new
                {
                    Name = "Star Conflicts Revolt",
                    Version = "1.0.0",
                    Environment = "Development"
                },
                Authentication = new
                {
                    IsAuthenticated = isAuthenticated,
                    HasValidToken = hasValidToken,
                    TokenExpiry = tokenExpiry,
                    TokenTimeRemaining = tokenTimeRemaining,
                    CurrentToken = currentToken != null ? $"{currentToken[..Math.Min(20, currentToken.Length)]}..." : null
                },
                Connection = new
                {
                    GameServerConnected = GameState.IsConnected,
                    SignalRConnected = signalRConnected,
                    LastUpdate = lastUpdate
                },
                Session = new
                {
                    CurrentSession = GameState.CurrentSession != null ? new
                    {
                        Id = GameState.CurrentSession.Id,
                        Name = GameState.CurrentSession.SessionName,
                        Type = GameState.CurrentSession.SessionType,
                        IsActive = GameState.CurrentSession.IsActive,
                        Created = GameState.CurrentSession.Created
                    } : null,
                    CurrentWorld = GameState.CurrentWorld != null ? new
                    {
                        Id = GameState.CurrentWorld.Id,
                        GalaxyId = GameState.CurrentWorld.Galaxy.Id,
                        StarSystemsCount = GameState.CurrentWorld.Galaxy.StarSystems.Count()
                    } : null
                },
                Statistics = new
                {
                    SignalR = new
                    {
                        MessageCount = signalRMessageCount,
                        ReconnectCount = signalRReconnectCount,
                        LastMessage = lastSignalRMessage
                    },
                    HTTP = new
                    {
                        RequestCount = httpRequestCount,
                        ErrorCount = httpErrorCount,
                        AverageResponseTime = averageResponseTime
                    }
                },
                Performance = new
                {
                    MemoryUsageMB = memoryUsage,
                    CpuUsagePercent = cpuUsage,
                    Uptime = uptime,
                    ActiveConnections = activeConnections
                },
                ActivityLog = activityLog.Take(10).Select(log => new
                {
                    Timestamp = log.Timestamp,
                    Type = log.Type,
                    Message = log.Message
                }).ToArray()
            };

            rawStateJson = System.Text.Json.JsonSerializer.Serialize(state, new System.Text.Json.JsonSerializerOptions
            {
                WriteIndented = true,
                PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase
            });
        }
        catch (Exception ex)
        {
            rawStateJson = $"Error generating state: {ex.Message}";
            AddLogEntry("error", $"Error updating raw state: {ex.Message}");
        }
    }

    private async Task CopyStateToClipboard()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", rawStateJson);
            AddLogEntry("success", "Raw state copied to clipboard");
        }
        catch (Exception ex)
        {
            AddLogEntry("error", $"Failed to copy to clipboard: {ex.Message}");
        }
    }

    private async Task RunHealthCheck(string path)
    {
        healthCheckRunning = true;
        healthCheckResults = null;
        healthCheckResult = null;
        StateHasChanged();
        try
        {
            var sw = System.Diagnostics.Stopwatch.StartNew();
            var response = await HttpApiClient.GetResponseAsync(path, default);
            sw.Stop();
            var body = await response.Content.ReadAsStringAsync();
            if (body.Length > 500) body = body.Substring(0, 500) + "...";
            healthCheckResult = new HealthCheckResult
            {
                Path = path,
                StatusCode = (int)response.StatusCode,
                DurationMs = sw.ElapsedMilliseconds,
                Body = body,
                Error = null
            };
            AddLogEntry("info", $"Health check {path}: {(int)response.StatusCode} ({sw.ElapsedMilliseconds} ms)");
        }
        catch (Exception ex)
        {
            healthCheckResult = new HealthCheckResult
            {
                Path = path,
                StatusCode = -1,
                DurationMs = 0,
                Body = null,
                Error = ex.Message
            };
            AddLogEntry("error", $"Health check {path}: {ex.Message}");
        }
        healthCheckRunning = false;
        StateHasChanged();
    }

    private async Task RunAllHealthChecks()
    {
        healthCheckRunning = true;
        healthCheckResult = null;
        healthCheckResults = new List<HealthCheckResult>();
        StateHasChanged();
        foreach (var path in new[] { "/", "/health", "/health/game" })
        {
            try
            {
                var sw = System.Diagnostics.Stopwatch.StartNew();
                var response = await HttpApiClient.GetResponseAsync(path, default);
                sw.Stop();
                var body = await response.Content.ReadAsStringAsync();
                if (body.Length > 400) body = body.Substring(0, 400) + "...";
                healthCheckResults.Add(new HealthCheckResult
                {
                    Path = path,
                    StatusCode = (int)response.StatusCode,
                    DurationMs = sw.ElapsedMilliseconds,
                    Body = body,
                    Error = null
                });
            }
            catch (Exception ex)
            {
                healthCheckResults.Add(new HealthCheckResult
                {
                    Path = path,
                    StatusCode = -1,
                    DurationMs = 0,
                    Body = null,
                    Error = ex.Message
                });
            }
        }
        healthCheckRunning = false;
        StateHasChanged();
    }

    private sealed class HealthCheckResult
    {
        public string Path { get; set; } = "";
        public int StatusCode { get; set; }
        public long DurationMs { get; set; }
        public string? Body { get; set; }
        public string? Error { get; set; }
    }

    private sealed record ServerEventBatch(DateTime Timestamp, long? TickNumber, List<GameObjectUpdate> Updates);

    private async Task RequestNewToken()
    {
        try
        {
            if (!isFirstRender)
            {
                await JsInterop.LogInfoAsync("Requesting new token");
            }
            AddLogEntry("info", "Requesting new token...");
            
            // Force token refresh by clearing cache if possible
            if (TokenProvider != null)
            {
                // Try to get a fresh token
                currentToken = await TokenProvider.GetTokenAsync();
                hasValidToken = !string.IsNullOrEmpty(currentToken);
                
                if (hasValidToken)
                {
                    var timeRemaining = TimeSpan.FromHours(1);
                    tokenExpiry = DateTime.UtcNow.Add(timeRemaining);
                    tokenTimeRemaining = timeRemaining.ToString(@"hh\:mm\:ss");
                    isAuthenticated = true;
                    
                    AddLogEntry("success", "New token obtained successfully");
                    if (!isFirstRender)
                    {
                        await JsInterop.LogInfoAsync("New token obtained successfully");
                    }
                }
                else
                {
                    AddLogEntry("error", "Failed to obtain new token");
                    if (!isFirstRender)
                    {
                        await JsInterop.LogErrorAsync("Failed to obtain new token");
                    }
                }
            }
            else
            {
                AddLogEntry("error", "Token provider not available");
                if (!isFirstRender)
                {
                    await JsInterop.LogErrorAsync("Token provider not available");
                }
            }
        }
        catch (Exception ex)
        {
            AddLogEntry("error", $"Error requesting new token: {ex.Message}");
            if (!isFirstRender)
            {
                await JsInterop.LogErrorAsync($"Error requesting new token: {ex.Message}");
                await JsInterop.LogExceptionAsync(ex);
            }
        }
    }

    public void Dispose()
    {
        refreshTimer?.Dispose();
        
        // Unsubscribe from all events
        SignalRService.FullWorldReceived -= OnFullWorldReceived;
        SignalRService.TickReceived -= OnTickReceived;
        SignalRService.UpdatesReceived -= OnSignalRMessage;
        SignalRService.ConnectionClosed -= OnSignalRConnectionClosed;
        SignalRService.Reconnecting -= OnSignalRReconnecting;
        SignalRService.Reconnected -= OnSignalRReconnected;
        GameState.StateChanged -= OnGameStateChanged;
    }
}

