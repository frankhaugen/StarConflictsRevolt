@page "/singleplayer"
@rendermode InteractiveServer
@using StarConflictsRevolt.Clients.Blazor.Services
@using StarConflictsRevolt.Clients.Models
@inject IGameStateService GameState
@inject TelemetryService TelemetryService
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Single Player</PageTitle>

<GameLayout SidebarTitle="Game">
    <SessionInfo>
        <GameSessionInfo Session="GameState.CurrentSession"
                         CreatingMessage="Creating game…"
                         ShowResources="true"
                         Resources="_resources"
                         ShowTurn="true"
                         Turn="_turn"
                         Phase="_phase" />
        <GameSpeedControl />
    </SessionInfo>
    <QuickActions>
        <button type="button" class="btn btn-outline-primary btn-sm" @onclick="() => _showFleet = true" data-testid="fleet-manager-btn"><i class="fas fa-ship"></i> Fleet</button>
        <button type="button" class="btn btn-outline-success btn-sm" @onclick="() => _showPlanet = true" data-testid="planet-manager-btn"><i class="fas fa-globe"></i> Planets</button>
        <button type="button" class="btn btn-outline-warning btn-sm" @onclick="AddMessage"><i class="fas fa-handshake"></i> Diplomacy</button>
    </QuickActions>
    <ChildContent>
        <div data-testid="game-container" class="position-relative min-vh-100" style="background: linear-gradient(45deg, #0a0a0a, #1a1a2e);">
            <GalaxyMap Systems="GameState.CurrentWorld?.Galaxy?.StarSystems"
                       OnSelect="OnSystemSelected"
                       EmptyMessage="No star systems. Create from Home."
                       ShowLoading="GameState.CurrentWorld?.Galaxy?.StarSystems == null"
                       LoadingMessage="@(GameState.CurrentSession == null ? "Creating galaxy…" : "Loading…")" />
            <SelectedSystemCard Selected="_selected" />
            <GameMessagesPanel Messages="_messages" OnClear="ClearMessages" />
        </div>
    </ChildContent>
</GameLayout>

@if (_showFleet) { <FleetManager OnClose="() => _showFleet = false" /> }
@if (_showPlanet) { <PlanetManager OnClose="() => _showPlanet = false" /> }

@code {
    private StarSystemDto? _selected;
    private bool _showFleet, _showPlanet;
    private int _turn = 1;
    private string _phase = "Planning";
    private List<GameMessagesPanel.GameMessageItem> _messages = new();
    private Dictionary<string, int> _resources = new() { ["credits"] = 1000, ["materials"] = 500, ["fuel"] = 200 };

    protected override void OnInitialized()
    {
        GameState.StateChanged += OnStateChanged;
        if (GameState.CurrentSession == null) _ = Task.Run(StartNewGame);
        AddMessage("info", "Welcome! Your galactic empire awaits.");
    }

    void OnStateChanged() => _ = InvokeAsync(StateHasChanged);

    private async Task StartNewGame()
    {
        if (await GameState.CreateSessionAsync("Single Player Game"))
            AddMessage("success", "Game created.");
        else
            AddMessage("error", "Failed to create game.");
        OnStateChanged();
    }

    private void OnSystemSelected(StarSystemDto s)
    {
        _selected = s;
        AddMessage("info", $"Selected {s.Name}");
        TelemetryService.RecordGameAction("select_star_system");
    }

    private void AddMessage() => AddMessage("info", "Diplomacy coming soon.");
    private void AddMessage(string type, string text)
    {
        _messages.Insert(0, new GameMessagesPanel.GameMessageItem { Timestamp = DateTime.Now, Type = type, Text = text });
        if (_messages.Count > 50) _messages = _messages.Take(50).ToList();
    }
    private void ClearMessages() => _messages.Clear();

    public void Dispose() => GameState.StateChanged -= OnStateChanged;
}

