@page "/sessions"
@using StarConflictsRevolt.Clients.Blazor.Services
@using StarConflictsRevolt.Clients.Models
@inject IGameStateService GameState
@inject NavigationManager Navigation

<PageTitle>Join Session</PageTitle>

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h3 data-testid="sessions-title">Available Sessions</h3>
                    <div>
                        <button data-testid="refresh-btn" class="btn btn-outline-primary me-2" @onclick="RefreshSessions" disabled="@isLoading">
                            @if (isLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            }
                            else
                            {
                                <i class="fas fa-sync-alt"></i>
                            }
                            Refresh
                        </button>
                        <button data-testid="back-btn" class="btn btn-outline-secondary" @onclick="NavigateToHome">
                            <i class="fas fa-arrow-left"></i> Back to Menu
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    @if (isLoading)
                    {
                        <LoadingState Message="Loading sessions…" Size="LoadingState.LoadingSize.Medium" />
                    }
                    else if (sessions.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Session Name</th>
                                        <th>Players</th>
                                        <th>Status</th>
                                        <th>Created</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var session in sessions)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@session.SessionName</strong>
                                                @if (session.Id == GameState.CurrentSession?.Id)
                                                {
                                                    <span class="badge bg-success ms-2">Current</span>
                                                }
                                            </td>
                                            <td>
                                                <span class="badge bg-info">@session.SessionType</span>
                                            </td>
                                            <td>
                                                @if (session.IsActive)
                                                {
                                                    <span class="badge bg-success">Active</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning">Waiting</span>
                                                }
                                            </td>
                                            <td>@session.Created.ToString("MMM dd, yyyy HH:mm")</td>
                                            <td>
                                                @if (session.Id == GameState.CurrentSession?.Id)
                                                {
                                                    <button class="btn btn-success btn-sm" @onclick="NavigateToGalaxy">
                                                        <i class="fas fa-play"></i> <text>Continue</text>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-primary btn-sm" @onclick="() => JoinSession(session.Id)"
                                                            disabled="@isJoining" title="Join this session">
                                                        @if (joiningSessionId == session.Id)
                                                        {
                                                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                                            <text>Joining…</text>
                                                        }
                                                        else
                                                        {
                                                            <i class="fas fa-sign-in-alt"></i> <text>Join</text>
                                                        }
                                                    </button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <EmptyState Title="No sessions yet"
                                   Description="Create your first game to see it here, or ask a friend for their session link."
                                   IconClass="fas fa-globe">
                            <button class="btn btn-primary btn-lg" @onclick="NavigateToSinglePlayer">
                                <i class="fas fa-plus me-2"></i> Create new game
                            </button>
                        </EmptyState>
                    }
                </div>
            </div>

            <ErrorBanner Message="@errorMessage" Dismissible="true" OnDismiss="ClearError" />
        </div>
    </div>
</div>

@code {
    private List<SessionDto> sessions = new();
    private bool isLoading = false;
    private bool isJoining = false;
    private Guid? joiningSessionId = null;
    private string? errorMessage;

    private void ClearError() { errorMessage = null; }

    protected override async Task OnInitializedAsync()
    {
        await RefreshSessions();
    }

    private async Task RefreshSessions()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            sessions = await GameState.GetAvailableSessionsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading sessions: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void NavigateToHome()
    {
        Navigation.NavigateTo("/");
    }

    private void NavigateToGalaxy()
    {
        Navigation.NavigateTo("/galaxy");
    }

    private void NavigateToSinglePlayer()
    {
        Navigation.NavigateTo("/singleplayer");
    }

    private async Task JoinSession(Guid sessionId)
    {
        isJoining = true;
        joiningSessionId = sessionId;
        errorMessage = null;

        try
        {
            var success = await GameState.JoinSessionAsync(sessionId);
            if (success)
            {
                Navigation.NavigateTo("/singleplayer");
            }
            else
            {
                errorMessage = "Could not join this session. Please try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isJoining = false;
            joiningSessionId = null;
        }
    }
}
