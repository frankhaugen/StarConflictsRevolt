@page "/options"
@using StarConflictsRevolt.Clients.Blazor.Services
@inject IGameStateService GameState
@inject NavigationManager Navigation

<PageTitle>Options</PageTitle>

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="text-center mb-5">
                <h1 data-testid="options-title" class="display-4 text-primary">Options</h1>
                <p class="lead">Configure your game settings</p>
            </div>
            
            @if (!string.IsNullOrEmpty(optionsMessage))
            {
                <div class="alert @(optionsMessageType == "success" ? "alert-success" : "alert-danger") alert-dismissible fade show mb-3" role="alert">
                    <i class="fas @(optionsMessageType == "success" ? "fa-check-circle" : "fa-exclamation-circle") me-2"></i>@optionsMessage
                    <button type="button" class="btn-close" aria-label="Dismiss" @onclick="ClearOptionsMessage"></button>
                </div>
            }

            <div class="card scr-card">
                <div class="card-header">
                    <h3>Game Settings</h3>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="playerName" class="form-label">Player Name</label>
                                <input type="text" class="form-control" id="playerName" value="Player" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label for="gameSpeed" class="form-label">Game Speed</label>
                                <select class="form-select" id="gameSpeed">
                                    <option value="slow">Slow</option>
                                    <option value="normal" selected>Normal</option>
                                    <option value="fast">Fast</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="checkbox" id="soundEnabled" checked />
                                <label class="form-check-label" for="soundEnabled">
                                    Sound Effects
                                </label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check mb-3">
                                <input class="form-check-input" type="checkbox" id="musicEnabled" checked />
                                <label class="form-check-label" for="musicEnabled">
                                    Background Music
                                </label>
                            </div>
                        </div>
                    </div>
                    
                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <button data-testid="save-btn" class="btn btn-primary" @onclick="SaveOptions">
                            <i class="fas fa-save"></i> Save Settings
                        </button>
                        <button data-testid="reset-btn" class="btn btn-secondary" @onclick="ResetOptions">
                            <i class="fas fa-undo"></i> Reset to Defaults
                        </button>
                    </div>
                </div>
            </div>
            
            <div class="card mt-3">
                <div class="card-header">
                    <h3>Navigation</h3>
                </div>
                <div class="card-body">
                    <div data-testid="navigation-buttons" class="d-grid gap-2">
                        <button data-testid="back-btn" class="btn btn-secondary" @onclick="NavigateToHome">
                            <i class="fas fa-arrow-left"></i> Back to Menu
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string? optionsMessage;
    private string optionsMessageType = "success";

    private void SaveOptions()
    {
        // TODO: Persist to backend when implemented
        optionsMessage = "Settings saved.";
        optionsMessageType = "success";
    }

    private void ResetOptions()
    {
        // TODO: Reset to defaults when implemented
        optionsMessage = "Settings reset to defaults.";
        optionsMessageType = "success";
    }

    private void ClearOptionsMessage()
    {
        optionsMessage = null;
    }

    private void NavigateToHome()
    {
        Navigation.NavigateTo("/");
    }
}
