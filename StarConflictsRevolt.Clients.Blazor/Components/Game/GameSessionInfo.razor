@* Session card and optional resources/turn for the game sidebar. *@
@using StarConflictsRevolt.Clients.Models
@if (Session != null)
{
    <div class="card bg-secondary mb-3">
        <div class="card-body py-2">
            <h6 class="mb-0">@Session.SessionName</h6>
            <p class="small mb-0">@Session.SessionType · @(Session.IsActive ? "Active" : "Waiting")</p>
        </div>
    </div>
}
else
{
    <div class="card bg-secondary mb-3 opacity-75">
        <div class="card-body py-2"><p class="small mb-0 text-muted"><i class="fas fa-spinner fa-spin me-1"></i> @CreatingMessage</p></div>
    </div>
}
@if (ShowResources && Resources != null)
{
    <div class="mb-3 small">
        <div><i class="fas fa-coins text-warning me-1"></i> @Resources.GetValueOrDefault("credits", 0)</div>
        <div><i class="fas fa-cube text-info me-1"></i> @Resources.GetValueOrDefault("materials", 0)</div>
        <div><i class="fas fa-fire text-danger me-1"></i> @Resources.GetValueOrDefault("fuel", 0)</div>
    </div>
}
@if (ShowTurn && Turn > 0)
{
    <div class="small text-muted">Turn @Turn · @Phase</div>
}

@code {
    [Parameter] public SessionDto? Session { get; set; }
    [Parameter] public string CreatingMessage { get; set; } = "Creating game…";
    [Parameter] public bool ShowResources { get; set; }
    [Parameter] public IReadOnlyDictionary<string, int>? Resources { get; set; }
    [Parameter] public bool ShowTurn { get; set; }
    [Parameter] public int Turn { get; set; } = 1;
    [Parameter] public string Phase { get; set; } = "Planning";
}
