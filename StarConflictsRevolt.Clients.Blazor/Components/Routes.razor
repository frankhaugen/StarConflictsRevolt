@using Microsoft.AspNetCore.Components.Web
@inject NavigationManager NavigationManager

<Router AppAssembly="typeof(Program).Assembly">
    <Found Context="routeData">
        <Microsoft.AspNetCore.Components.Web.ErrorBoundary>
            <ChildContent>
                <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
                <FocusOnNavigate RouteData="routeData" Selector="h1" />
            </ChildContent>
            <ErrorContent>
                <PageTitle>Error</PageTitle>
                <LayoutView Layout="typeof(Layout.MainLayout)">
                    <div class="container py-5">
                        <div class="row justify-content-center">
                            <div class="col-md-6">
                                <div class="card border-danger scr-card">
                                    <div class="card-body text-center py-4">
                                        <i class="fas fa-exclamation-triangle text-danger fa-3x mb-3" aria-hidden="true"></i>
                                        <h1 class="h4">Something went wrong</h1>
                                        <p class="text-muted mb-4">An error occurred while loading this page. Try reloading or go back to Home.</p>
                                        <a href="/" class="btn btn-primary me-2"><i class="fas fa-home me-1"></i> Go Home</a>
                                        <button type="button" class="btn btn-outline-secondary" @onclick="() => NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true)"><i class="fas fa-redo me-1"></i> Reload</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </LayoutView>
            </ErrorContent>
        </Microsoft.AspNetCore.Components.Web.ErrorBoundary>
    </Found>
    <NotFound>
        <PageTitle>Not found</PageTitle>
        <LayoutView Layout="typeof(Layout.MainLayout)">
            <div class="container py-5">
                <div class="row justify-content-center">
                    <div class="col-md-6">
                        <div class="card scr-card border-0 shadow">
                            <div class="card-body text-center py-5">
                                <h1 class="display-4 text-muted fw-light">404</h1>
                                <h2 class="h4 mb-3">Page not found</h2>
                                <p class="text-muted mb-4">The page you're looking for doesn't exist or was moved.</p>
                                <a href="/" class="btn btn-primary">
                                    <i class="fas fa-home me-1"></i> Go Home
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </LayoutView>
    </NotFound>
</Router>
