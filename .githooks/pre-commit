#!/usr/bin/env bash
# Pre-commit hook: runs generate-slnx when relevant paths are staged.
# Runs in Git Bash on Windows, /bin/sh on macOS/Linux.
# Copy tools/ and .githooks/ to any repo — discovers .slnx dynamically.
set -euo pipefail

# --- Sentinel values (do not modify without updating both pre-commit and pre-commit.ps1) ---
# Recursion guard: skip if generator is already running
SLNX_GENERATOR_RUNNING_ENV="SLNX_GENERATOR_RUNNING"

# Root-level files excluded from triggering the generator (in addition to *.slnx, *.user)
EXCLUDED_ROOT_FILES="pull_request_template.md"

# --- End sentinel values ---

if [ "${!SLNX_GENERATOR_RUNNING_ENV:-}" = "1" ]; then
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0

# Find script (tools/generate-slnx.cs relative to repo root)
script_path="$repo_root/tools/generate-slnx.cs"
[ ! -f "$script_path" ] && exit 0

# Discover .slnx in repo root — exit gracefully if none
slnx_file=""
for f in "$repo_root"/*.slnx; do
  [ -f "$f" ] && slnx_file="$(basename "$f")" && break
done
[ -z "$slnx_file" ] && exit 0

# Collect staged paths (use -z for safe parsing of paths with newlines)
staged_paths=""
while IFS= read -r -d '' path; do
  staged_paths="${staged_paths}${path}"$'\n'
done < <(git diff --cached --name-only -z 2>/dev/null) || true

if [ -z "${staged_paths}" ]; then
  exit 0
fi

# Check for relevant paths: docs/**, Deployment/**, or root-level (excluding sentinels)
has_relevant=0
only_slnx=1
while IFS= read -r path; do
  [ -z "$path" ] && continue
  case "$path" in *.slnx) : ;; *) only_slnx=0 ;; esac
  case "$path" in
    docs/*|Deployment/*) has_relevant=1 ;;
    */*) : ;;
    *.slnx|*.user) : ;;
    "$EXCLUDED_ROOT_FILES") : ;;
    *) has_relevant=1 ;;
  esac
done <<< "$staged_paths"

[ "$only_slnx" = 1 ] && exit 0
[ "$has_relevant" = 0 ] && exit 0

if ! command -v dotnet &>/dev/null; then
  echo "generate-slnx: warning: dotnet not found, skipping (commit allowed)"
  exit 0
fi

cd "$repo_root"
export SLNX_GENERATOR_RUNNING=1
if ! dotnet run --file "$script_path" -- "$slnx_file"; then
  echo "generate-slnx: generator failed. Run manually to fix:"
  echo "  dotnet run --file tools/generate-slnx.cs -- $slnx_file"
  exit 1
fi
unset SLNX_GENERATOR_RUNNING 2>/dev/null || true

if ! git diff --quiet -- "$slnx_file"; then
  git add "$slnx_file"
  echo "generate-slnx: updated and staged $slnx_file"
else
  echo "generate-slnx: no changes"
fi

exit 0
